      ],
      "proponents": [
        "Jakze"
      ],
      "perform_instructions": "Orient your car upside down. Perform a front flip, then immediately cancel it with a diagonal input (down-right or down-left depending on which side your wheels point toward) to secure wheel contact with the ball for the reset.",
      "correction_notes": "Updated to clarify inverted front flip + diagonal cancel mechanic. Emphasizes the tilt-dependent input direction."
    },
