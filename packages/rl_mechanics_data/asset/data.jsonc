      ]
    },
    {
      "id": "evample-reset",
      "name": "Evample Reset",
      "description": "A reset technique initiated from the wall with the ball. The player quickly maneuvers above the ball, then performs a flat stall at a specific time to move towards the ball and obtain a reset from its top or top-side surface.",
