      "id": "tko-reset",
      "name": "TKO Reset",
      "description": "A reset technique involving a speedflip preflip into the ball. Instead of immediately getting the reset like a Rapid Reset, the player achieves a slight initial touch, continues rotating the car, and then obtains the reset slightly later by rotating back under the ball and correctly orienting the wheels.",
      "category": "flip_reset",
      "type": "air",
      "difficulty": 85,
      "viability": 25,
      "tags": [
        "flip_reset",
        "aerial",
        "speedflip_motion",
        "preflip",
        "rotation"
      ],
      "prerequisites": [
        "flip-reset"
      ],
      "proponents": [
        "TKO"
      ],
      "perform_instructions": "Use a speedflip preflip to approach the ball. Make initial contact (slight touch), continue rotating your car through the flip motion, and secure wheel contact with the ball as you complete the rotation and reorient underneath it.",
      "correction_notes": "Updated to clarify speedflip-preflip approach with initial touch followed by rotation to secure reset. Distinguishes from Rapid Reset which gets immediate contact."
    },
    {
      "id": "purple-shot",
      "name": "Purple Shot",
      "description": "A powerful shot, initially exclusive to Rocket League Sideswipe and later discovered in the main game. It involves an Arsenal Reset-like setup but with a specific flip execution that causes the ball to pop away from the car with immense power. The player retains their flip and control, allowing for backboard plays or ground flicks.",
      "category": "flip_reset",
      "type": "air",
      "difficulty": 85,
      "viability": 15,
