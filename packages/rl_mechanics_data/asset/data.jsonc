    {
      "id": "shay-reset",
      "name": "Shay Reset",
      "description": "A challenging freestyle mechanic. Immediately after obtaining a flip reset, the player rotates their car away from the ball, orienting the nose sideways relative to the ball. A backward diagonal flip is then executed into the ball to achieve another reset.",
      "category": "flip_reset",
      "type": "air",
      "difficulty": 90,
      "viability": 10,
      "tags": [
        "flip_reset",
        "aerial",
        "sideways_orientation",
